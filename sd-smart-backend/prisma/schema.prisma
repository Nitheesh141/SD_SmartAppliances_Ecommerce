// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  phoneNumber String?  @unique
  password    String
  firstName   String
  lastName    String
  role        String   @default("user")
  companyName String?
  gstin       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cart        Cart?
  wishlist    Wishlist?
  addresses   Address[]
  orders      Order[]
}

model OtpVerification {
  id        String   @id @default(uuid())
  phone     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordReset {
  id        String   @id @default(uuid())
  email     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Product {
  id                 String                 @id @default(uuid())
  name               String
  category           String
  categoryLabel      String
  image              String
  rating             Float                  @default(5.0)
  reviewCount        Int                    @default(0)
  price              Float
  originalPrice      Float
  discountPercent    Int                    @default(0)
  warranty           String                 @default("1 Year")
  productDescription String?
  badge              String?
  href               String                 @default("")
  inStock            Boolean                @default(true)
  isBestSeller       Boolean                @default(false)
  isFeatured         Boolean                @default(false)
  eyebrow            String?
  description        String?
  specs              Json? // Stores array of {label, value}
  startingPrice      Float?
  primaryCTALabel    String?
  primaryCTAHref     String?
  secondaryCTALabel  String?
  secondaryCTAHref   String?
  imagePosition      String?                @default("left")
  modelNumber        String?
  productId          String?
  sku                String?                @unique
  variantDetails     Json?
  availableStock     Int                    @default(0)
  stockIn            Int                    @default(0)
  stockOut           Int                    @default(0)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  transactions       InventoryTransaction[]
  cartItems          CartItem[]
  wishlistItems      WishlistItem[]
  orderItems         OrderItem[]
}

model InventoryTransaction {
  id        String   @id @default(uuid())
  productId String
  type      String // "IN" or "OUT"
  quantity  Int
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model DeletedModel {
  id        String   @id @default(uuid())
  category  String
  name      String
  createdAt DateTime @default(now())

  @@unique([category, name])
}

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
}

model Wishlist {
  id        String         @id @default(uuid())
  userId    String         @unique
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     WishlistItem[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model WishlistItem {
  id         String   @id @default(uuid())
  wishlistId String
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([wishlistId, productId])
}

model Address {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName     String
  emailAddress String?
  mobileNumber String
  companyName  String?
  addressLine1 String
  addressLine2 String?
  landmark     String?
  city         String
  state        String
  pincode      String
  gstin        String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
}

model Order {
  id              String               @id @default(uuid())
  orderNumber     String               @unique
  userId          String
  user            User                 @relation(fields: [userId], references: [id])
  addressId       String
  address         Address              @relation(fields: [addressId], references: [id])
  poNumber        String?
  paymentMethod   String
  status          String               @default("PENDING_APPROVAL")
  subtotal        Float
  cgst            Float
  sgst            Float
  igst            Float                @default(0)
  deliveryCharges Float
  discount        Float
  grandTotal      Float
  items           OrderItem[]
  approvedAt      DateTime?
  approvedBy      String?
  rejectionReason String?
  statusHistory   OrderStatusHistory[]
  invoice         Invoice?
  paymentStatus   String               @default("PENDING")
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

model OrderStatusHistory {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    String
  remarks   String?
  updatedBy String
  updatedAt DateTime @default(now())
}

model Invoice {
  id             String   @id @default(uuid())
  invoiceNumber  String   @unique
  orderId        String   @unique
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  distributorId  String
  subtotal       Float
  discountAmount Float
  taxAmount      Float
  shippingAmount Float
  grandTotal     Float
  invoiceDate    DateTime @default(now())
  pdfUrl         String?
  generatedBy    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Int
  unitPrice   Float
  createdAt   DateTime @default(now())
}

// Unified Offer model (Polymorphic JSON configuration)
model Offer {
  id                  String   @id @default(uuid())
  name                String
  code                String   @unique
  description         String?
  offerType           String   // e.g. "PRODUCT_DISCOUNT", "COUPON", "BOGO", "FLASH_SALE", etc.
  bannerImage         String?
  priority            Int      @default(0)
  status              String   @default("ACTIVE") // "ACTIVE", "INACTIVE", "SCHEDULED"
  startDate           DateTime
  endDate             DateTime
  applyAutomatically  Boolean  @default(true)
  stackable           Boolean  @default(false)
  maxUsageLimit       Int?
  usagePerCustomer    Int?     @default(1)
  displayBadgeText    String?
  badgeColor          String?  @default("red")
  termsConditions     String?
  
  // Single JSON configuration column to store type-specific rules
  configuration       Json     @default("{}")
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdBy           String?
  lastModifiedBy      String?
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
